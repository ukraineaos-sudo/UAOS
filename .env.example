# =============================================================================
# UAOS — environment
# Copy to `.env.local` (site) and `studio/.env` (Studio). Never commit secrets.
# =============================================================================

# --- Sanity (public, safe in browser / Vite) ---
# Create at https://www.sanity.io/manage — project "uaos", dataset "production"
VITE_SANITY_PROJECT_ID="yourProjectId"
VITE_SANITY_DATASET="production"
# Studio URL after `cd studio && npx sanity deploy` (e.g. https://uaos.sanity.studio)
VITE_SANITY_STUDIO_URL="http://localhost:3333"

# --- Sanity Studio (studio/.env uses same names without VITE_ prefix) ---
# SANITY_STUDIO_PROJECT_ID=yourProjectId
# SANITY_STUDIO_DATASET=production

# --- Server-only (Vercel Project Settings → Environment Variables) ---
# Create token: Sanity Manage → API → Tokens → Editor (write)
# Used by /api/join to save membership applications. NEVER prefix with VITE_
SANITY_API_WRITE_TOKEN=""

# Optional: notify admin by email via Formspree (https://formspree.io)
# FORMSPREE_JOIN_ENDPOINT="https://formspree.io/f/xxxxxxxx"

# Legacy AI Studio placeholders (unused by current frontend)
GEMINI_API_KEY=""
APP_URL=""
